[Unit]
Description=9beads Task Server for %i
Documentation=https://github.com/lneely/9beads
After=network.target

[Service]
Type=simple
User=%i
Group=%i
WorkingDirectory=/home/%i

Environment="PATH=/home/%i/bin:/usr/local/bin:/usr/bin:/bin"
Environment="HOME=/home/%i"

ExecStart=/home/%i/bin/Beads fgstart

Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
